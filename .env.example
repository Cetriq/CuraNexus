# CuraNexus Docker Environment Configuration
# Copy this file to .env and adjust as needed

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Database URLs for modules
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Main database (patient, care-encounter, journal, task, authorization)
CURANEXUS_DB_NAME=curanexus
CURANEXUS_DB_URL=jdbc:postgresql://postgres:5432/curanexus
CURANEXUS_DB_USERNAME=postgres
CURANEXUS_DB_PASSWORD=postgres

# Audit database
AUDIT_DB_NAME=curanexus_audit
AUDIT_DB_URL=jdbc:postgresql://postgres:5432/curanexus_audit
AUDIT_DB_USERNAME=postgres
AUDIT_DB_PASSWORD=postgres

# Triage database
TRIAGE_DB_NAME=curanexus_triage
TRIAGE_DB_URL=jdbc:postgresql://postgres:5432/curanexus_triage
TRIAGE_DB_USERNAME=postgres
TRIAGE_DB_PASSWORD=postgres

# Service URLs (for integration/gateway module)
PATIENT_SERVICE_URL=http://patient:8080
ENCOUNTER_SERVICE_URL=http://care-encounter:8081
JOURNAL_SERVICE_URL=http://journal:8082
TASK_SERVICE_URL=http://task:8083
AUTHORIZATION_SERVICE_URL=http://authorization:8084
AUDIT_SERVICE_URL=http://audit:8086
TRIAGE_SERVICE_URL=http://triage:8087

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@curanexus.se
PGADMIN_DEFAULT_PASSWORD=admin

# JVM Options (optional, defaults are set in Dockerfile)
# JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0

# Spring Profiles (optional)
# SPRING_PROFILES_ACTIVE=docker
